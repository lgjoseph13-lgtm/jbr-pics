<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1, viewport-fit=cover"
  >

  <meta
    name="description"
    content="Upload photos from the JBR 46th Atlanta Family Reunion."
  >

  <meta name="theme-color" content="#fffaf2">

  <title>JBR 46th Atlanta | Share Photos</title>

  <!-- Uploadcare uploader styling -->
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/@uploadcare/file-uploader@v1/web/uc-file-uploader-regular.min.css"
  >

  <!-- Our custom website styling -->
  <link rel="stylesheet" href="styles.css">
</head>

<body>
  <main class="page-container">

    <section class="upload-card">

      <div class="peach-decoration peach-top" aria-hidden="true">
        🍑
      </div>

      <div class="peach-decoration peach-bottom" aria-hidden="true">
        🍑
      </div>

      <header class="hero">
        <p class="reunion-label">46th Family Reunion</p>

        <h1>JBR Atlanta</h1>

        <p class="tagline">
          Share the moments that made this reunion special.
        </p>
      </header>

      <section class="welcome-message">
        <h2>Share Your Reunion Photos</h2>

        <p>
          Upload pictures directly from your phone. You may select several
          photos at once or take a new picture with your camera.
        </p>
      </section>

      <section class="steps" aria-label="Photo upload instructions">

        <article class="step-card">
          <span class="step-number">1</span>

          <div>
            <h3>Choose photos</h3>
            <p>Select pictures from your phone or use your camera.</p>
          </div>
        </article>

        <article class="step-card">
          <span class="step-number">2</span>

          <div>
            <h3>Upload</h3>
            <p>Tap the upload button and keep the page open.</p>
          </div>
        </article>

        <article class="step-card">
          <span class="step-number">3</span>

          <div>
            <h3>Finished</h3>
            <p>Wait for the confirmation before closing the page.</p>
          </div>
        </article>

      </section>

      <div class="no-app-message">
        <strong>No app or guest account required.</strong>
        <span>Your photos will go directly to the reunion collection.</span>
      </div>

      <section class="uploader-area" aria-labelledby="upload-heading">

        <h2 id="upload-heading">Upload Your Pictures</h2>

        <p class="uploader-description">
          You can upload up to 50 images at a time.
        </p>

        <!--
          IMPORTANT:
          Replace YOUR_UPLOADCARE_PUBLIC_KEY with your actual
          Uploadcare public key.

          Do not put your secret key anywhere in this website.
        -->
        <uc-config
          id="uploadcare-config"
          ctx-name="jbr-photo-uploader"
          pubkey="YOUR_UPLOADCARE_PUBLIC_KEY"
          img-only="true"
          multiple="true"
          multiple-max="50"
          max-local-file-size-bytes="26214400"
          source-list="local, camera"
          confirm-upload="true"
          store="auto">
        </uc-config>

        <uc-upload-ctx-provider
          id="upload-context"
          ctx-name="jbr-photo-uploader">
        </uc-upload-ctx-provider>

        <uc-file-uploader-regular
          ctx-name="jbr-photo-uploader">
        </uc-file-uploader-regular>

        <div
          id="upload-status"
          class="upload-status"
          role="status"
          aria-live="polite"
        >
          Tap the button above to select your reunion photos.
        </div>

      </section>

      <section class="photo-reminders">
        <h2>Before You Upload</h2>

        <p>
          Please upload family-friendly pictures from the JBR reunion only.
        </p>

        <p>
          Uploading may take longer when using cellular data or selecting a
          large group of photos.
        </p>
      </section>

      <footer>
        <p class="thank-you">
          Thank you for helping us preserve our family memories.
        </p>

        <p class="footer-name">
          JBR 46th Atlanta Family Reunion
        </p>
      </footer>

    </section>

  </main>

  <noscript>
    <div class="javascript-warning">
      JavaScript must be enabled to upload photos.
    </div>
  </noscript>

  <script type="module" src="app.js"></script>
</body>
</html>
